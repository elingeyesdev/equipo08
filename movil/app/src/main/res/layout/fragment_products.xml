<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@color/bg_dark">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">



            <!-- CARD Form -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:backgroundTint="@android:color/white"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nuevo artículo"
                        android:textStyle="bold"
                        android:textColor="#2b3b55"
                        android:layout_marginBottom="16dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:boxBackgroundColor="#f1f5f9"
                        app:boxCornerRadiusTopStart="8dp"
                        app:boxCornerRadiusTopEnd="8dp"
                        app:boxStrokeWidth="0dp">
                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/etName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="56dp"
                            android:paddingTop="22dp"
                            android:paddingBottom="14dp"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:hint="Nombre del producto *"
                            android:inputType="text"
                            android:completionThreshold="1"
                            android:textColor="@color/primary_color" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:boxBackgroundColor="#f1f5f9"
                        app:boxCornerRadiusTopStart="8dp"
                        app:boxCornerRadiusTopEnd="8dp"
                        app:boxStrokeWidth="0dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Variante / especificación (opcional)"
                            android:textColor="@color/primary_color" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:id="@+id/llAttributesContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="12dp"
                        android:visibility="gone" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:boxBackgroundColor="#f1f5f9"
                        app:boxCornerRadiusTopStart="8dp"
                        app:boxCornerRadiusTopEnd="8dp"
                        app:boxStrokeWidth="0dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSku"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="SKU (código interno) *"
                            android:textColor="@color/primary_color" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView 
                        android:layout_width="wrap_content" 
                        android:layout_height="wrap_content" 
                        android:text="Categoría global *" 
                        android:textColor="#5a6a85"
                        android:layout_marginBottom="4dp"/>
                    <Spinner
                        android:id="@+id/spinnerCategoria"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/edit_text_bg"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            app:boxBackgroundColor="#f1f5f9"
                            app:boxCornerRadiusTopStart="8dp"
                            app:boxCornerRadiusTopEnd="8dp"
                            app:boxStrokeWidth="0dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etPrecioCoste"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Precio coste (Bs) *"
                                android:inputType="numberDecimal"
                                android:textColor="@color/primary_color" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            app:boxBackgroundColor="#f1f5f9"
                            app:boxCornerRadiusTopStart="8dp"
                            app:boxCornerRadiusTopEnd="8dp"
                            app:boxStrokeWidth="0dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etPrecioVenta"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Precio venta pública (Bs) *"
                                android:inputType="numberDecimal"
                                android:textColor="@color/primary_color" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <TextView 
                        android:layout_width="wrap_content" 
                        android:layout_height="wrap_content" 
                        android:text="Proveedor habitual *" 
                        android:textColor="#5a6a85"
                        android:layout_marginBottom="4dp"/>
                    <Spinner
                        android:id="@+id/spinnerProveedor"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/edit_text_bg"
                        android:layout_marginBottom="12dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:boxBackgroundColor="#f1f5f9"
                        app:boxCornerRadiusTopStart="8dp"
                        app:boxCornerRadiusTopEnd="8dp"
                        app:boxStrokeWidth="0dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etStockMinimo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Stock mínimo alerta (por defecto 10)"
                            android:inputType="number"
                            android:textColor="@color/primary_color" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Image Selection Layout -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Imagen del producto (opcional)"
                            android:textColor="#5a6a85"
                            android:textSize="12sp"
                            android:layout_marginBottom="8dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <ImageView
                                android:id="@+id/ivProductPreview"
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:scaleType="centerCrop"
                                android:background="#f1f5f9"
                                android:layout_marginEnd="12dp"
                                android:visibility="gone" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnSelectProductImage"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Subir imagen"
                                    android:textSize="12sp"
                                    app:backgroundTint="@color/accent_color"
                                    android:textColor="@color/white"
                                    app:rippleColor="#ffffff" />

                                <TextView
                                    android:id="@+id/tvImageStatus"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="No se ha seleccionado imagen"
                                    android:textSize="11sp"
                                    android:textColor="#5a6a85"
                                    android:layout_marginTop="4dp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvRemoveProductImage"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Quitar"
                                android:textColor="#2563eb"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:padding="8dp"
                                android:visibility="gone" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView 
                        android:layout_width="wrap_content" 
                        android:layout_height="wrap_content" 
                        android:text="Margen de ganancia %" 
                        android:textColor="#5a6a85"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/tvMargen"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#f1f5f9"
                        android:padding="12dp"
                        android:text="0%"
                        android:textStyle="bold"
                        android:textColor="@color/primary_color"
                        android:layout_marginBottom="16dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGuardar"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        app:cornerRadius="8dp"
                        android:backgroundTint="#0f172a"
                        android:textColor="#ffffff"
                        android:text="Anexar artículo" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- LIST AREA -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingBottom="80dp"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnToggleForm"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@drawable/ic_add"
        app:backgroundTint="#0f172a"
        app:tint="#ffffff"
        android:contentDescription="Acción" />

</FrameLayout>
