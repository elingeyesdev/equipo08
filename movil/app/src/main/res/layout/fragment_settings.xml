<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            

            <!-- Card Settings Form -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSettingsForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:backgroundTint="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Perfil y marca"
                        android:textStyle="bold"
                        android:textColor="#0f172a"
                        android:textSize="16sp"
                        android:layout_marginBottom="20dp"/>

                    <!-- Store Name -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:boxBackgroundColor="#f1f5f9"
                        app:boxCornerRadiusTopStart="8dp"
                        app:boxCornerRadiusTopEnd="8dp"
                        app:boxStrokeWidth="0dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSettingsStoreName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Nombre de la tienda *"
                            android:inputType="text"
                            android:textColor="#0f172a" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Contact Phone -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:boxBackgroundColor="#f1f5f9"
                        app:boxCornerRadiusTopStart="8dp"
                        app:boxCornerRadiusTopEnd="8dp"
                        app:boxStrokeWidth="0dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSettingsContactPhone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Teléfono de contacto (WhatsApp)"
                            android:inputType="phone"
                            android:textColor="#0f172a" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Logo Upload Layout -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Logo de la empresa (opcional)"
                            android:textColor="#5a6a85"
                            android:textSize="12sp"
                            android:layout_marginBottom="8dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:id="@+id/ivSettingsLogoPreview"
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:scaleType="centerCrop"
                                android:background="#f1f5f9"
                                android:layout_marginEnd="12dp"
                                android:visibility="gone" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnSelectSettingsLogo"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Subir logo"
                                    android:textSize="12sp"
                                    app:backgroundTint="@color/profit_color"
                                    android:textColor="@color/white"
                                    app:cornerRadius="16dp" />

                                <TextView
                                    android:id="@+id/tvSettingsLogoStatus"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="No se ha seleccionado logo"
                                    android:textSize="11sp"
                                    android:textColor="#5a6a85"
                                    android:layout_marginTop="4dp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvRemoveSettingsLogo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Quitar"
                                android:textColor="#2563eb"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:padding="8dp"
                                android:visibility="gone" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Brand Color Selection -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Color de marca"
                        android:textColor="@color/accent_color"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="24dp"
                        android:visibility="gone">

                        <!-- Color Preview Box -->
                        <View
                            android:id="@+id/viewSettingsColorPreview"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_circle_white"
                            android:backgroundTint="@color/accent_color"
                            android:layout_marginEnd="12dp" />

                        <!-- Brand Color Text Input -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            app:boxBackgroundColor="#f1f5f9"
                            app:boxCornerRadiusTopStart="8dp"
                            app:boxCornerRadiusTopEnd="8dp"
                            app:boxStrokeWidth="0dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etSettingsBrandColor"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Código color (HEX) *"
                                android:inputType="text"
                                android:textColor="#0f172a"
                                android:maxLines="1" />
                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <!-- Save Changes Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSettingsSave"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        app:cornerRadius="8dp"
                        android:backgroundTint="#0f172a"
                        android:textColor="#ffffff"
                        android:text="Guardar cambios"
                        android:textStyle="bold" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Center Progress Loading -->
    <ProgressBar
        android:id="@+id/pbSettingsLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminateTint="@color/accent_color" />

</FrameLayout>
