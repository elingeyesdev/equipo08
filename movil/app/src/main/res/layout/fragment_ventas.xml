<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="16dp">

    <!-- History RecyclerView with SwipeRefresh -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshHistory"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Toggle Filters Button -->
                <Button
                    android:id="@+id/btnToggleHistoryFilters"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp"
                    android:text="Filtrar ventas"
                    android:textSize="12sp"
                    android:backgroundTint="@color/accent_color"
                    android:textColor="#ffffff" />

                <!-- History Filters Panel -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardHistoryFilters"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#ffffff">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <EditText
                            android:id="@+id/etSearchHistory"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:hint="Buscar por cliente o documento..."
                            android:background="@drawable/edit_text_bg"
                            android:paddingHorizontal="10dp"
                            android:drawableStart="@drawable/ic_search"
                            android:drawableTint="@color/primary_color"
                            android:drawablePadding="8dp"
                            android:textColor="@color/primary_color"
                            android:textColorHint="@color/primary_color"
                            android:textSize="13sp"
                            android:layout_marginBottom="8dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">

                            <Button
                                android:id="@+id/btnDateFromHistory"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="36dp"
                                android:text="Desde"
                                android:textSize="11sp"
                                android:backgroundTint="#f1f5f9"
                                android:textColor="#475569"
                                android:layout_marginEnd="4dp" />

                            <Button
                                android:id="@+id/btnDateToHistory"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="36dp"
                                android:text="Hasta"
                                android:textSize="11sp"
                                android:backgroundTint="#f1f5f9"
                                android:textColor="#475569"
                                android:layout_marginStart="4dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">

                            <RelativeLayout
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="40dp"
                                android:layout_marginEnd="4dp"
                                android:background="@drawable/edit_text_bg">

                                <Spinner
                                    android:id="@+id/spinnerBranchHistory"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@null"
                                    android:paddingStart="8dp"
                                    android:paddingEnd="24dp" />

                                <ImageView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:src="@drawable/ic_chevron_down"
                                    android:layout_alignParentEnd="true"
                                    android:layout_centerVertical="true"
                                    android:layout_marginEnd="8dp"
                                    app:tint="@color/primary_color" />
                            </RelativeLayout>

                            <RelativeLayout
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="40dp"
                                android:layout_marginStart="4dp"
                                android:background="@drawable/edit_text_bg">

                                <Spinner
                                    android:id="@+id/spinnerPaymentHistory"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@null"
                                    android:paddingStart="8dp"
                                    android:paddingEnd="24dp" />

                                <ImageView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:src="@drawable/ic_chevron_down"
                                    android:layout_alignParentEnd="true"
                                    android:layout_centerVertical="true"
                                    android:layout_marginEnd="8dp"
                                    app:tint="@color/primary_color" />
                            </RelativeLayout>
                        </LinearLayout>

                        <Button
                            android:id="@+id/btnClearHistoryFilters"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:layout_gravity="end"
                            android:text="Limpiar filtros"
                            android:textSize="11sp"
                            android:backgroundTint="@color/primary_color"
                            android:textColor="#ffffff" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- History RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSalesHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingBottom="12dp"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>
