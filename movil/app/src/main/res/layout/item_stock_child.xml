<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="24dp"
    android:layout_marginEnd="8dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp"
    android:backgroundTint="#f8fafc">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        
        <TextView
            android:id="@+id/tvTreeLine"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="└─ "
            android:textColor="#cbd5e1"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        
        <TextView
            android:id="@+id/tvVariant"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Variante / Atributos"
            android:textColor="#0f172a"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginStart="4dp"
            app:layout_constraintStart_toEndOf="@+id/tvTreeLine"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/tvStock"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tvStock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 U"
            android:textColor="@color/profit_color"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvMinStock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Min: 10"
            android:textColor="@color/profit_color"
            android:textSize="11sp"
            android:layout_marginTop="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvStock" />

        
        <TextView
            android:id="@+id/tvSku"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SKU"
            android:textColor="#64748b"
            android:textSize="11sp"
            android:layout_marginTop="4dp"
            app:layout_constraintStart_toStartOf="@+id/tvVariant"
            app:layout_constraintTop_toBottomOf="@+id/tvVariant" />

        <TextView
            android:id="@+id/tvSucursal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Sucursal"
            android:textColor="@color/primary_color"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            app:layout_constraintStart_toStartOf="@+id/tvVariant"
            app:layout_constraintTop_toBottomOf="@+id/tvSku"
            app:layout_constraintEnd_toStartOf="@+id/tvMinStock"
            android:layout_marginEnd="8dp" />

        
        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#f1f5f9"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@+id/tvSucursal" />

        <TextView
            android:id="@+id/tvLabelCosto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Costo U."
            android:textColor="@color/profit_color"
            android:textSize="11sp"
            android:layout_marginTop="6dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/divider" />

        <TextView
            android:id="@+id/tvCostoFijo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bs 0.00"
            android:textColor="#475569"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvLabelCosto" />

        <TextView
            android:id="@+id/tvLabelValuacion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Valuación Parcial"
            android:textColor="@color/profit_color"
            android:textSize="11sp"
            android:layout_marginTop="6dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/divider" />

        <TextView
            android:id="@+id/tvValuacion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bs 0.00"
            android:textColor="#0f172a"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvLabelValuacion" />

        <Button
            android:id="@+id/btnTrasladar"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#EBF5FB"
            android:textColor="@color/primary_color"
            android:text="Trasladar"
            android:textSize="11sp"
            android:padding="0dp"
            app:layout_constraintTop_toBottomOf="@+id/tvValuacion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
