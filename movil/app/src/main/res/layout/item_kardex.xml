<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp"
    android:backgroundTint="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        
        <LinearLayout
            android:id="@+id/llKardexLeftBadge"
            android:layout_width="72dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:background="#f1f5f9">

            <TextView
                android:id="@+id/tvKardexDelta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+20"
                android:textColor="#0f172a"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvKardexOpBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="COMPRA"
                android:textColor="#475569"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="12dp">

            
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvKardexSucursal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sucursal: Centro"
                    android:textColor="#1e293b"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_alignParentStart="true"/>

                <TextView
                    android:id="@+id/tvKardexFecha"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="30/06/2026, 00:11"
                    android:textColor="#64748b"
                    android:textSize="11sp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>

            
            <TextView
                android:id="@+id/tvKardexOperador"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Operador: Administrador"
                android:textColor="#475569"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvKardexSku"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="SKU: IWIEJQAI"
                android:textColor="#64748b"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:visibility="gone" />

            
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                
                <TextView
                    android:id="@+id/tvKardexStockChange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stock: 18 ➔ 13"
                    android:textColor="#0f172a"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_alignParentStart="true"/>

                
                <TextView
                    android:id="@+id/tvKardexCostoUnitario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Costo: Bs 700.00"
                    android:textColor="#0d9488"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>

            
            <TextView
                android:id="@+id/tvKardexMotivo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Ref: Ajuste manual por inventario"
                android:textColor="#64748b"
                android:textSize="11sp"
                android:textStyle="italic"
                android:visibility="gone" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
