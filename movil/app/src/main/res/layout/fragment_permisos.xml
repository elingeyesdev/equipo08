<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f8f9fc">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gestión de Permisos"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#2b3b55"
            android:layout_marginBottom="4dp"/>
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Define qué accesos tienen los diferentes roles dentro del sistema."
            android:textColor="#5a6a85"
            android:layout_marginBottom="16dp"/>

        <!-- SUPERVISOR CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:backgroundTint="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SUPERVISOR"
                        android:textStyle="bold"
                        android:textColor="#3b82f6"
                        android:textSize="16sp"
                        android:layout_centerVertical="true"
                        android:drawablePadding="8dp" />

                    <Button
                        android:id="@+id/btnAplicarSupervisor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:backgroundTint="#3b82f6"
                        android:textColor="#ffffff"
                        android:textSize="12sp"
                        android:text="Aplicar Perfil" />
                </RelativeLayout>

                <!-- Container for toggles -->
                <LinearLayout
                    android:id="@+id/llSupervisorPermisos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- VENDEDOR CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:backgroundTint="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VENDEDOR"
                        android:textStyle="bold"
                        android:textColor="#eab308"
                        android:textSize="16sp"
                        android:layout_centerVertical="true"
                        android:drawablePadding="8dp" />

                    <Button
                        android:id="@+id/btnAplicarVendedor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:backgroundTint="#1d4ed8"
                        android:textColor="#ffffff"
                        android:textSize="12sp"
                        android:text="Aplicar Perfil" />
                </RelativeLayout>

                <!-- Container for toggles -->
                <LinearLayout
                    android:id="@+id/llVendedorPermisos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
