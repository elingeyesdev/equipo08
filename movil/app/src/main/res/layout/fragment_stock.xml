<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/btnToggleFilter"
                android:layout_marginEnd="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inventario y Valuación"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#2b3b55" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Operando bajo centros de costos segregados."
                    android:textColor="#5a6a85" />
            </LinearLayout>

            <Button
                android:id="@+id/btnToggleFilter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:backgroundTint="#2563eb"
                android:textColor="#ffffff"
                android:text="Filtrar" />
        </RelativeLayout>

        <!-- Alert Banner -->
        <LinearLayout
            android:id="@+id/llAlertBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_warning_red"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_dialog_alert"
                android:layout_marginEnd="12dp"
                app:tint="#b91c1c" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvAlertTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alertas de Inventario Bajo (0)"
                    android:textColor="#991b1b"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hay productos que se encuentran por debajo del stock mínimo configurado. Recomendamos generar reposiciones."
                    android:textColor="#b91c1c"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- FILTER AREA -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            android:backgroundTint="@android:color/white"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Branch Spinner -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/edit_text_bg"
                    android:padding="8dp"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_mylocation"
                        app:tint="#5a6a85"
                        android:layout_marginEnd="8dp"/>

                    <Spinner
                        android:id="@+id/spinnerSucursal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null" />
                </LinearLayout>

                <!-- Search Input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:boxBackgroundMode="none"
                    app:hintEnabled="false"
                    app:endIconMode="clear_text"
                    app:endIconTint="#5a6a85">

                    <EditText
                        android:id="@+id/etSearch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Buscar por producto o SKU..."
                        android:background="@drawable/edit_text_bg"
                        android:padding="12dp"
                        android:drawableStart="@android:drawable/ic_menu_search"
                        android:drawablePadding="8dp"
                        android:textColor="#2b3b55"
                        android:inputType="text"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Simulate Button -->
                <Button
                    android:id="@+id/btnSimulateAlerts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Simular Escenario de Bajo Stock"
                    android:backgroundTint="#f43f5e"
                    android:textColor="#ffffff"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Valuation Box -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#f1f5f9"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inversión Física Total (A Costo):"
                    android:textColor="#5a6a85"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Valuación de Déficit Acumulado:"
                    android:textColor="#991b1b"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">
                <TextView
                    android:id="@+id/tvTotalValuation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bs. 0.00"
                    android:textColor="#2b3b55"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvTotalDeficit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bs. 0.00"
                    android:textColor="#b91c1c"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- LIST AREA -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:paddingBottom="80dp"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
