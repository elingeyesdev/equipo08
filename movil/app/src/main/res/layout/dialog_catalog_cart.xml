<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#0C1929"
    android:padding="20dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_input_add"
            app:tint="#34D399" />

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Mi Pedido"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnCatalogCartClose"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#94A3B8" />

    </LinearLayout>

    <!-- Empty cart message -->
    <TextView
        android:id="@+id/tvCatalogCartEmpty"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:gravity="center"
        android:text="Tu carrito está vacío."
        android:textColor="#94A3B8"
        android:textSize="14sp"
        android:visibility="gone" />

    <!-- Cart items list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCatalogCartItems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="300dp"
        android:layout_marginBottom="16dp" />

    <!-- Checkout section -->
    <LinearLayout
        android:id="@+id/llCatalogCartCheckout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0A1624"
        android:padding="16dp"
        android:backgroundTint="#111C2E"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Total estimado"
                android:textColor="#94A3B8"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCatalogCartTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bs 0.00"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <Button
            android:id="@+id/btnCatalogCartConfirm"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#10B981"
            android:text="CONFIRMAR POR WHATSAPP"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Serás redirigido a WhatsApp para enviar el detalle de tu pedido."
            android:textColor="#475569"
            android:textSize="11sp"
            android:gravity="center" />

    </LinearLayout>

</LinearLayout>
