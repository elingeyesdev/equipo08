<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="8dp"
    android:backgroundTint="#fffbeb">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="12dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="⚠ Acta de Auditoría de Stock (Ajuste Físico)"
                android:textColor="#b45309"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnClose"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="#b45309" />
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#fcd34d"
            android:layout_marginBottom="16dp"/>

        <!-- Info Text -->
        <TextView
            android:id="@+id/tvAuditInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Estás auditando [Producto] en [Sucursal]. Actualmente el sistema registra [XX] unidades."
            android:textColor="#92400e"
            android:textSize="14sp"
            android:layout_marginBottom="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">
            
            <!-- Left Column: Cantidad -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Conteo Físico Real (Unidades) *"
                    android:textColor="#92400e"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/etCantidadFisica"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:inputType="number"
                    android:hint="Ej: 9"
                    android:padding="12dp"
                    android:background="@drawable/edit_text_bg"
                    android:backgroundTint="@android:color/white" />
            </LinearLayout>

            <!-- Right Column: Motivo -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Motivo Oficial (Obligatorio) *"
                    android:textColor="#92400e"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinnerMotivo"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:backgroundTint="@android:color/white" />
            </LinearLayout>
        </LinearLayout>

        <!-- Dynamic Warning Box -->
        <LinearLayout
            android:id="@+id/llWarningBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_warning_red"
            android:padding="16dp"
            android:layout_marginTop="20dp"
            android:visibility="gone">
            
            <TextView
                android:id="@+id/tvWarningText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚠ Impacto Financiero Directo: La diferencia de 1 unidades resultará en una pérdida de valuación..."
                android:textColor="#991b1b"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Observaciones Cuantitativas (Opcional)"
            android:textColor="#92400e"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etObservaciones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Detalles sobre el hallazgo de la diferencia de inventario..."
            android:padding="16dp"
            android:background="@drawable/edit_text_bg"
            android:backgroundTint="@android:color/white"
            android:textSize="14sp" />

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="24dp">
            
            <Button
                android:id="@+id/btnCancelar"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Cancelar Vuelo"
                android:textColor="#b45309"
                android:backgroundTint="#fffbeb"
                android:layout_marginEnd="12dp"
                style="?android:attr/borderlessButtonStyle" />

            <Button
                android:id="@+id/btnProcesar"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Procesar Acta"
                android:textColor="@android:color/white"
                android:backgroundTint="#d97706"
                android:paddingHorizontal="16dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
