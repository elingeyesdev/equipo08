<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    android:backgroundTint="@android:color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2026-04-29 10:00:00"
            android:textColor="#5a6a85"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvProductName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Producto Nombre"
            android:textColor="#2b3b55"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvDate"
            app:layout_constraintEnd_toStartOf="@+id/tvDelta"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tvDelta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-1 U"
            android:textColor="#991b1b"
            android:background="#fee2e2"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:textStyle="bold"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tvProductName"
            app:layout_constraintBottom_toBottomOf="@+id/tvProductName"/>

        <TextView
            android:id="@+id/tvSucursal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Sucursal"
            android:textColor="#5a6a85"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvProductName" />

        <TextView
            android:id="@+id/tvOperador"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Operador"
            android:textColor="#5a6a85"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvProductName" />

        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#f1f5f9"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@+id/tvSucursal" />

        <TextView
            android:id="@+id/tvMotivo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Error de Registro"
            android:background="#f1f5f9"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:textColor="#475569"
            android:textSize="12sp"
            android:layout_marginTop="12dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/divider" />

        <TextView
            android:id="@+id/tvLoss"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bs. 100.00"
            android:textColor="#b91c1c"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tvMotivo"
            app:layout_constraintBottom_toBottomOf="@+id/tvMotivo"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
