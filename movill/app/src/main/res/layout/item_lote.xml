<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:background="?android:attr/selectableItemBackground">

    <TextView
        android:id="@+id/tvTrx"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:textColor="#5a6a85"
        android:text="TRX" />

    <TextView
        android:id="@+id/tvFecha"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:textColor="#2b3b55"
        android:text="Fecha" />

    <TextView
        android:id="@+id/tvProducto"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:textColor="#5a6a85"
        android:text="Producto" />

    <TextView
        android:id="@+id/tvProveedor"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:textColor="#2b3b55"
        android:text="Proveedor" />

    <TextView
        android:id="@+id/tvVolumen"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:textColor="#10b981"
        android:textStyle="bold"
        android:text="Volumen" />

    <TextView
        android:id="@+id/tvPrecioU"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:textColor="#5a6a85"
        android:text="Precio U." />

    <TextView
        android:id="@+id/tvInversion"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:textColor="#2b3b55"
        android:textStyle="bold"
        android:text="Inversion" />

</LinearLayout>
